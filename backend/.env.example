# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Supabase
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
# Get these from: https://dashboard.stripe.com/apikeys (use test keys)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create these products in Stripe Dashboard → Products
STRIPE_MONTHLY_PRICE_ID=price_monthly_id_here
STRIPE_YEARLY_PRICE_ID=price_yearly_id_here

# JWT (generate a strong random string, e.g. openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email (Resend) — optional, emails are stubbed if not set
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Frontend URL (for Stripe redirect and CORS)
FRONTEND_URL=http://localhost:5173
